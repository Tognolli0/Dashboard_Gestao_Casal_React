{
  "outputDirectory": "wwwroot",
  "rewrites": [
    {
      "source": "/_framework/(.*)",
      "destination": "/_framework/$1"
    },
    {
      "source": "/_content/(.*)",
      "destination": "/_content/$1"
    },
    {
      "source": "/css/(.*)",
      "destination": "/css/$1"
    },
    {
      "source": "/favicon.png",
      "destination": "/favicon.png"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}